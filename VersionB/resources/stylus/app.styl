* 
*::before
*::after
  box-sizing border-box

body
  margin 0
  font-family 'Manrope', sans-serif
  background #f4f4f6
  color #252336

.base
  min-height 100vh
  display flex
  align-items center
  justify-content center
  padding 24px

.base__container
  width min(100%, 760px)
  padding 32px
  border 1px solid #d8d8df
  border-radius 16px
  background #ffffff

.base__title
  margin 0 0 12px
  font-size 2rem
  line-height 1.2

.base__text
  margin 0
  font-size 1rem
  line-height 1.6
  color #5e5b73
